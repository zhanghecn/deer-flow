# Shared app env (root `.env`)
#
# This is the single app config for:
# - `make dev`
# - `make docker-start`
# - host-run gateway / LangGraph / migrate
# - containerized gateway / LangGraph
#
# Rule:
# - keep canonical app values here
# - container-only fixed URLs live in `docker-compose-dev.yaml`

# Core runtime
DATABASE_URI=postgresql://root:zhangxuan66.@127.0.0.1:5432/openagents?sslmode=disable
LANGGRAPH_URL=http://localhost:2024
JWT_SECRET=kxkK2WpkhrHTHhD7Jged3wT9N3x2P5o07ehWh2hoy2u8k9vuPVSEVPcMlc3evcF2
OPENAGENTS_HOME=.openagents

# Managed AIO sandbox for local dev/debug.
# Host-run development expects this endpoint to be provided separately,
# for example via `make docker-infra-start`.
# Dockerized LangGraph is overridden in compose to `http://sandbox-aio:8080`.
OPENAGENTS_SANDBOX_BASE_URL=http://127.0.0.1:8083

# Optional skill/API keys
ARK_API_KEY=32a0e8cb-ffa6-4687-96fd-5da2da9d73df
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5.0-lite
GEMINI_API_KEY=AIzaSyCKb37Kp5h2hQXf-Xw-oU7u_8oNl622a1M

# ONLYOFFICE local debug defaults.
# Host-run development expects this endpoint to be provided separately,
# for example via `make docker-infra-start`.
# ONLYOFFICE itself runs in Docker, so it must call back into the host gateway
# through the explicit `openagents-host` alias rather than the container-local
# `localhost`.
# Dockerized gateway overrides ONLYOFFICE_PUBLIC_APP_URL inline in compose.
ONLYOFFICE_SERVER_URL=http://localhost:8082
ONLYOFFICE_PUBLIC_APP_URL=http://openagents-host:8001
# Leave ONLYOFFICE_JWT_SECRET unset to reuse JWT_SECRET and avoid drift.
# ONLYOFFICE_JWT_SECRET=

# Optional Docker / compose-only overrides.
# Leave these commented unless you want to change compose defaults.
# OPENAGENTS_DOCKER_HOST_HOME=/absolute/path/to/.openagents
# SANDBOX_AIO_PORT=8083
# SANDBOX_AIO_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
ONLYOFFICE_PORT=8082
# NGINX_CONF=nginx.conf

# Provisioner mode only
# SANDBOX_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
# K8S_NAMESPACE=openagents
# NODE_HOST=192.168.1.10
# KUBECONFIG_PATH=/root/.kube/config
# K8S_API_SERVER=https://your-k8s-api-host:26443
