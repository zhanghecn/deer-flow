# Shared runtime env (single source of truth)
#
# This file carries both:
# - host-view values used by local `make dev` / host-run services
# - `*_DOCKER` overrides used by `docker/docker-compose-dev.yaml`
#
# The suffix is intentional: `localhost` means something different on the host
# and inside a container.

# EXA API Key (optional for web_search via Exa MCP)
# EXA_API_KEY=your-exa-api-key

# Shared PostgreSQL DSN (Gateway + Backend runtime + LangGraph persistence)
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:5432/openagents?sslmode=disable
DATABASE_URI_DOCKER=postgresql://postgres:postgres@host.docker.internal:5432/openagents?sslmode=disable

# Shared LangGraph upstream URL used by gateway proxy/openapi.
LANGGRAPH_URL=http://localhost:2024
LANGGRAPH_URL_DOCKER=http://langgraph:2024

# LangGraph runtime edition (`inmem` recommended for OSS/dev; `postgres` requires extra backend package)
LANGGRAPH_RUNTIME_EDITION=inmem

# Optional: only needed when LANGGRAPH_RUNTIME_EDITION=postgres
# REDIS_URI=redis://127.0.0.1:6379/0

# Gateway JWT signing key
JWT_SECRET=your-jwt-secret-here

# Shared data root
# Use an absolute path in production/service deployments to avoid cwd-dependent resolution.
OPENAGENTS_HOME=.openagents
OPENAGENTS_HOME_DOCKER=/openagents-home
OPENAGENTS_DOCKER_HOST_HOME=../.openagents
OPENAGENTS_DOCKER_CONTAINER_HOME=/openagents-home
OPENAGENTS_SANDBOX_BASE_URL=http://127.0.0.1:8083
OPENAGENTS_SANDBOX_SHARED_DATA_MOUNT_PATH=/openagents
OPENAGENTS_SANDBOX_BASE_URL_DOCKER=http://sandbox-aio:8080
OPENAGENTS_SANDBOX_SHARED_DATA_MOUNT_PATH_DOCKER=/openagents
SANDBOX_AIO_PORT=8083
SANDBOX_AIO_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
SANDBOX_IMAGE_DOCKER=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
K8S_NAMESPACE_DOCKER=openagents
NODE_HOST_DOCKER=host.docker.internal
KUBECONFIG_PATH_DOCKER=/root/.kube/config
K8S_API_SERVER_DOCKER=https://host.docker.internal:26443

# CORS Origins (comma-separated) - e.g., http://localhost:3000,http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Optional:
# FIRECRAWL_API_KEY=your-firecrawl-api-key
# ARK_API_KEY=your-volcengine-ark-api-key
# VOLCENGINE_API_KEY=your-volcengine-api-key
# VOLCENGINE_IMAGE_MODEL=doubao-seedream-5.0-lite  # model alias, model ID, or endpoint ID
# VOLCENGINE_IMAGE_SIZE=2560x1440
# ARK_USE_SYSTEM_PROXY=true
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai

# ONLYOFFICE direct office document editing
# The Docker dev image extends ONLYOFFICE Docs 9.3.1 Build 10 and installs Noto CJK fonts
# for better Chinese document rendering.
# Browser-facing ONLYOFFICE URL. This is consumed by the web UI, so it normally
# stays host-view even when gateway runs in Docker.
# ONLYOFFICE_SERVER_URL=http://localhost:8082
# Gateway URL reachable from the ONLYOFFICE container.
# For the unified Docker dev compose, use http://gateway:8001.
# For a host-run gateway, use http://host.docker.internal:8001.
# ONLYOFFICE_PUBLIC_APP_URL=http://host.docker.internal:8001
# ONLYOFFICE_PUBLIC_APP_URL_DOCKER=http://gateway:8001
# Shared JWT secret used by gateway + ONLYOFFICE Document Server.
# ONLYOFFICE_JWT_SECRET=replace-with-a-random-64-char-secret
# Host port for the ONLYOFFICE container
# ONLYOFFICE_PORT=8082
