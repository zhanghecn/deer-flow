{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["../../apps/web/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": []
}
