# OpenAgents production Docker environment.
# Copy to docker/.env manually or run: ./scripts/docker-deploy.sh

OPENAGENTS_IMAGE_REGISTRY=docker.io
OPENAGENTS_IMAGE_REPOSITORY=zhangxuan2/openagents
OPENAGENTS_IMAGE_TAG=latest

OPENAGENTS_ENV_FILE=.env
OPENAGENTS_CONFIG_FILE=./config.yaml
OPENAGENTS_GATEWAY_CONFIG_FILE=./gateway.yaml

OPENAGENTS_APP_PORT=8083
OPENAGENTS_ADMIN_PORT=8081
OPENAGENTS_POSTGRES_PORT=15432
OPENAGENTS_MINIO_API_PORT=19000
OPENAGENTS_MINIO_CONSOLE_PORT=19001
OPENAGENTS_ONLYOFFICE_PORT=8082
OPENAGENTS_SANDBOX_PORT=18080

OPENAGENTS_DOCKER_HOST_HOME=./data/openagents
OPENAGENTS_POSTGRES_DATA_DIR=./data/postgres
OPENAGENTS_MINIO_DATA_DIR=./data/minio

OPENAGENTS_POSTGRES_DB=openagents
OPENAGENTS_POSTGRES_USER=openagents
OPENAGENTS_POSTGRES_PASSWORD=

OPENAGENTS_MINIO_ROOT_USER=openagents
OPENAGENTS_MINIO_ROOT_PASSWORD=
KNOWLEDGE_OBJECT_STORE=minio
KNOWLEDGE_S3_ENDPOINT=http://minio:9000
KNOWLEDGE_S3_ACCESS_KEY=openagents
KNOWLEDGE_S3_SECRET_KEY=
KNOWLEDGE_S3_BUCKET=openagents-knowledge
KNOWLEDGE_S3_SECURE=false

JWT_SECRET=
TAVILY_API_KEY=
ARK_API_KEY=
GEMINI_API_KEY=
