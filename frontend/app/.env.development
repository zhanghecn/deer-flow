# 用户前台本地开发默认把 `/api`、`/open`、`/health`
# 代理到本机 gateway。
VITE_BACKEND_BASE_URL=http://localhost:8001

# 本地开发把同源 `/onlyoffice` 转发到本机 Document Server，
# 让浏览器访问路径尽量与生产 nginx 保持一致。
VITE_ONLYOFFICE_DEV_SERVER_URL=http://localhost:8082

# 开发环境默认不是纯静态只读模式。
VITE_STATIC_WEBSITE_ONLY=false

# 本地开发默认保留调试细节；可改为 user 作为用户友好默认展示。
VITE_MESSAGE_TRACE_DISPLAY_MODE=debug
