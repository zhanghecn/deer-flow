# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=openagents
DB_SSLMODE=disable

# JWT Secret (用于 gateway.yaml: secret: $JWT_SECRET)
JWT_SECRET=your-jwt-secret-here

# 存储目录
OPENAGENTS_HOME=.openagents

# LangGraph 地址
LANGGRAPH_URL=http://localhost:2024
