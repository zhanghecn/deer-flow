{
  "$schema": "https://langgra.ph/schema.json",
  "dependencies": [
    "."
  ],
  "env": "../../.env",
  "http": {
    "configurable_headers": {
      "includes": [
        "x-user-id",
        "x-thread-id"
      ]
    }
  },
  "checkpointer": {
    "backend": "custom",
    "path": "src.checkpointer.checkpointer"
  },
  "disable_persistence": true,
  "graphs": {
    "lead_agent": "src.agents:make_lead_agent"
  }
}
